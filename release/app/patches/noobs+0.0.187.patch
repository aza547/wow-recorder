+static void preload_macos_framework_dependencies(const std::string& basePath) {
+  const std::string frameworkPath = basePath + "Contents/Frameworks/";
+  const std::vector<std::string> dependencies = {
+    "libavcodec.dylib",
+    "libavdevice.dylib",
+    "libavfilter.dylib",
+    "libavformat.dylib",
+    "libavutil.dylib",
