+    "librist.dylib",
+    "libsrt.dylib",
+    "libswresample.dylib",
+    "libswscale.dylib",
+  };
+
+  for (const auto& dependency : dependencies) {
+    preload_macos_framework_dependency(frameworkPath + dependency);
+  }
+}
+
+static bool macos_path_exists(const std::string& path) {
+  return access(path.c_str(), F_OK) == 0;
+}
+
+static std::string macos_join_path(
+  const std::string& parent,
+  const std::string& child
+) {
+  if (parent.empty()) {
+    return child;
+  }
+
+  if (parent.back() == '/') {
+    return parent + child;
+  }
+
+  return parent + "/" + child;
+}
+
+static std::string macos_resolve_plugin_bundle(
+  const std::string& basePath,
+  const std::string& module
+) {
+  const std::string bundleName = module + ".plugin";
+  const char* overridePath = getenv("WCR_OBS_PLUGIN_PATH");
+
+  if (overridePath && overridePath[0] != '\0') {
+    const std::string candidate = macos_join_path(overridePath, bundleName);
+
+    if (macos_path_exists(candidate)) {
+      blog(LOG_INFO, "Using OBS plugin from WCR_OBS_PLUGIN_PATH: %s", candidate.c_str());
+      return candidate;
+    }
+  }
+
+  const std::string wcrCandidate =
+    basePath + "Contents/WCRPlugIns/" + bundleName;
+
+  if (macos_path_exists(wcrCandidate)) {
+    blog(LOG_INFO, "Using bundled WCR OBS plugin: %s", wcrCandidate.c_str());
+    return wcrCandidate;
+  }
+
+  return basePath + "Contents/PlugIns/" + bundleName;
+}
