{
  "name": "WarcraftRecorder",
  "version": "7.8.0",
  "description": "Warcraft Recorder",
  "main": "./dist/main/main.js",
  "author": {
    "name": "Alex K"
  },
  "scripts": {
    "electron-rebuild": "node -r ts-node/register ../../.erb/scripts/electron-rebuild.js",
    "link-modules": "node -r ts-node/register ../../.erb/scripts/link-modules.ts",
    "copy-noobs-addon": "node ../../scripts/noobs/copy-rebuilt-addon.js ./node_modules/noobs",
    "postinstall": "patch-package && npm run electron-rebuild && npm run copy-noobs-addon && npm run link-modules"
  },
  "dependencies": {
    "atomic-queue": "^5.0.4",
    "noobs": "^0.0.187",
    "uiohook-napi": "^1.5.2"
  },
  "license": "MIT",
  "devDependencies": {
    "patch-package": "^8.0.1"
  },
  "optionalDependencies": {
    "@ffmpeg-installer/darwin-arm64": "^4.1.5",
    "@ffmpeg-installer/darwin-x64": "^4.1.0"
  }
}
